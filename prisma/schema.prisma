generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = "postgresql://neondb_owner:npg_PJxz4Sf0seDh@ep-billowing-thunder-apg0dl64.c-7.us-east-1.aws.neon.tech/neondb?sslmode=require"
}

model Paciente {
  id           String   @id @default(uuid())
  email        String   @unique
  primeiroNome String
  sobreNome    String
  hash         String   // Necessário para o erro de 'hash'
  diarios      Diario[]
}

model Diario {
id          String   @id @default(uuid())
  titulo      String
  descricao   String
  conteudo    String
  createdAt   DateTime @default(now()) // Necessário para o erro de 'createdAt'
  pacienteId  String
  paciente    Paciente @relation(fields: [pacienteId], references: [id])
}