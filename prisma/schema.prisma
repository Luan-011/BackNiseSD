datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Paciente {
  id           String   @id @default(uuid())
  primeiroNome String
  sobreNome    String
  email        String   @unique
  hash         String
  diarios      Diario[]
}

model Diario {
  id          String   @id @default(uuid())
  createdAt   DateTime @default(now())
  titulo      String
  descricao   String   @db.Text
  conteudo    String
  dataRegistro DateTime // APENAS ESTE NOME
  feedbackIA  String?
  
  pacienteId  String
  paciente    Paciente @relation(fields: [pacienteId], references: [id])
}